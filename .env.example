# .env.example —— 帕奇宠 Agent 后端本地开发环境变量模板
#
# 首次使用：cp .env.example .env
# 然后根据本地环境编辑 .env 中的值
# .env 已加入 .gitignore，不会提交到仓库

# ========== PostgreSQL 数据库 ==========
# 格式：postgres://用户名:密码@主机:端口/数据库名?sslmode=disable
POSTGRES_DSN=postgres://patchpet:patchpet_dev@localhost:5432/patchpet?sslmode=disable

# ========== Redis ==========
REDIS_ADDR=localhost:6379
# Redis 密码，无密码留空
REDIS_PASSWORD=

# ========== LLM AI 服务（Python AI 服务配置在 ai-service/ 下） ==========
# LLM API Key，无可用 Key 时 AI 功能不可用，不影响服务启动
LLM_API_KEY=
# LLM API Base URL，留空使用默认
LLM_BASE_URL=

# ========== Go ↔ Python AI 服务通信 ==========
# Python AI 服务 gRPC 地址
AI_SERVICE_GRPC_ADDR=localhost:50051

# ========== 认证密钥（本地开发随意填写，生产环境必须为强密钥） ==========
JWT_SECRET=patchpet-local-dev-jwt-secret
REPLAY_SECRET_KEY=patchpet-local-dev-replay-secret

# ========== Unleash 功能开关 ==========
UNLEASH_URL=http://localhost:4242
UNLEASH_APP_NAME=patch-pet
UNLEASH_INSTANCE_ID=patch-pet-local

# ========== Kafka ==========
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ========== 日志 ==========
# development / production
APP_ENV=development

# ========== Python AI 服务自身配置 ==========
GRPC_HOST=0.0.0.0
GRPC_PORT=50051

# ========== Nacos 配置中心（可选，未集成时不配也不影响） ==========
# NACOS_ADDR=localhost
# NACOS_PORT=8848
# NACOS_NAMESPACE=patchpet
# NACOS_USERNAME=nacos
# NACOS_PASSWORD=nacos
